# Local SQLite database used by Prisma and the app runtime.
# For Railway with a mounted volume, use something like: file:/data/app.db
DATABASE_URL="file:./prisma/dev.db"

# Fake example secret for signing the auth session cookie. Replace with your own random 32+ character string.
AUTH_SECRET="replace-this-with-your-own-long-random-auth-secret"

# Demo credentials used by `npm run auth:seed-demo` for local development only.
DEMO_LOGIN_EMAIL="demo@example.com"
DEMO_LOGIN_PASSWORD="demo-password-change-me"
